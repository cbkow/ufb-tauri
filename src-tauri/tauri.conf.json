{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Union File Browser",
  "version": "0.1.4",
  "identifier": "com.unionfiles.ufb",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Union File Browser",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: http://localhost:* asset: https://asset.localhost; connect-src 'self' ws://localhost:* http://localhost:*; style-src 'self' 'unsafe-inline'; frame-src https://script.google.com https://docs.google.com https://drive.google.com https://*.googleusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis/hooks.nsh"
      }
    },
    "resources": [
      "icons/32x32.png",
      "assets/scripts/*",
      "assets/shell/shell.nss",
      "assets/shell/import/*",
      "assets/shell/regEntry/*",
      "assets/projectTemplate/**/*"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ufb"]
      }
    }
  }
}
